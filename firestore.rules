rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper Primitives
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // Booking Identity & Integrity
    function isValidBooking(data) {
      return data.keys().hasAll(['serviceName', 'price', 'date', 'time', 'createdAt'])
        && data.keys().size() == 5
        && data.serviceName is string && data.serviceName.size() >= 2 && data.serviceName.size() <= 100
        && data.price is string && data.price.size() >= 2 && data.price.size() <= 20
        && data.date is string && data.date.size() == 10
        && data.time is string && data.time.size() >= 4 && data.time.size() <= 10
        && data.createdAt == request.time;
    }

    match /bookings/{bookingId} {
      // Publicly readable so everyone can see blocked slots
      allow list, get: if true;
      
      // Anyone can book, but we enforce uniqueness via ID logic in code (day_time)
      // and strict validation here.
      allow create: if isValidBooking(incoming()) 
                   && isValidId(bookingId)
                   && !exists(/databases/$(database)/documents/bookings/$(bookingId));
      
      // Allow deletion for users to manage their own bookings (identified by possession of ID in frontend)
      allow delete: if true;
      
      // Prevent editing existing bookings
      allow update: if false;
    }
  }
}
