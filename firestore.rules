rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper Primitives
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // Booking Identity & Integrity
    function isValidBooking(data) {
      // Relaxed for debugging and ensuring functionality
      return data.keys().hasAll(['serviceName', 'price', 'date', 'time', 'status'])
        && data.serviceName is string
        && data.price is string
        && data.date is string
        && data.time is string
        && data.status in ['pendente', 'confirmado'];
    }

    match /bookings/{bookingId} {
      allow read, list, get: if true;
      
      allow write: if (
        isValidId(bookingId) &&
        (
          // Allow creation/update if the slot is not confirmed yet or it's the same owner (simplified)
          !exists(/databases/$(database)/documents/bookings/$(bookingId)) ||
          resource.data.status != 'confirmado'
        )
      );
      
      allow delete: if true;
    }
  }
}
