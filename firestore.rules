rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper Primitives
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // Booking Identity & Integrity
    function isValidBooking(data) {
      return data.keys().hasAll(['serviceName', 'price', 'date', 'time', 'status'])
        && data.serviceName is string
        && data.price is string
        && data.date is string
        && data.time is string
        && data.status in ['pendente', 'confirmado']
        // Optional auth fields
        && (data.keys().hasAny(['userId']) ? (data.userId == null || data.userId is string) : true);
    }

    match /bookings/{bookingId} {
      allow read, list, get: if true;
      
      allow write: if (
        isValidId(bookingId) &&
        (
          // Creation: allow if slot not confirmed
          (!exists(/databases/$(database)/documents/bookings/$(bookingId)) || resource.data.status != 'confirmado') &&
          // If a userId is being set, it must match the logged in user
          (incoming().get('userId', null) == null || incoming().userId == request.auth.uid)
        )
      );
      
      allow delete: if (
        // Allow delete if user owns it
        (resource.data.get('userId', null) != null && resource.data.userId == request.auth.uid) ||
        // Or if it was created anonymously (for now, to maintain compatibility with existing local storage logic)
        (resource.data.get('userId', null) == null) 
      );
    }
  }
}
