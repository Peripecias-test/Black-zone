rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny: Catch-all to ensure no data is public by default.
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Entity Validation: Ensures data follows the schema defined in firebase-blueprint.json
    function isValidBooking(data) {
      return data.keys().hasAll(['serviceName', 'price', 'date', 'time', 'status', 'createdAt'])
        && data.serviceName is string && data.serviceName.size() <= 100
        && data.price is string && data.price.size() <= 20
        && data.date is string && data.date.size() <= 20
        && data.time is string && data.time.size() <= 10
        && data.status in ['pendente', 'confirmado']
        // Identity Integrity: Prevent identity spoofing
        && (data.get('userId', null) == null || (data.userId is string && data.userId == request.auth.uid))
        && (data.get('userEmail', null) == null || data.userEmail is string)
        && (data.get('userName', null) == null || data.userName is string)
        && (data.get('userIP', null) == null || data.userIP is string)
        && data.createdAt is timestamp
        && (data.get('confirmedAt', null) == null || data.confirmedAt is timestamp);
    }

    match /bookings/{bookingId} {
      // Secure List Query: evaluations happen against resource properties.
      // We allow reading for availability logic, assuming sensitive data is handled in allow create/update.
      allow read, get, list: if true;
      
      allow create: if (
        isValidId(bookingId) &&
        isValidBooking(incoming()) &&
        // Slot Guard: Cannot book a slot that is already confirmed.
        (!exists(/databases/$(database)/documents/bookings/$(bookingId)) || existing().status != 'confirmado') &&
        // Identity: If logged in, must use own ID
        (incoming().get('userId', null) == null || incoming().userId == request.auth.uid) &&
        // Timestamp Integrity
        incoming().createdAt == request.time
      );

      allow update: if (
        isValidId(bookingId) &&
        isValidBooking(incoming()) &&
        // Identity protection: Cannot update someone else's confirmed booking.
        (existing().get('userId', null) == null || existing().userId == request.auth.uid) &&
        // Once a booking is confirmed, certain fields become immutable for non-admins.
        (existing().status != 'confirmado' || (
          incoming().userId == existing().userId &&
          incoming().serviceName == existing().serviceName &&
          incoming().date == existing().date &&
          incoming().time == existing().time
        )) &&
        // Action: Confirmation or Update. We allow 'createdAt' to be updated ONLY if moving from 'pendente'.
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'confirmedAt', 'userName', 'userEmail', 'userId', 'userIP', 'createdAt']))
      );
      
      allow delete: if (
        // Identity-based deletion
        (existing().get('userId', null) != null && existing().userId == request.auth.uid) ||
        // Support for anonymous deletions via local storage matching
        (existing().get('userId', null) == null) 
      );
    }
  }
}
